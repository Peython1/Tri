//# sourceMappingURL=adminlte.min.js.map;
function SetNavBar(idFs, idLi) {
    if ($("fieldset:visible").find(':input').valid()) {

        $("#BarraProgresso li").removeClass("active");
        switch (idLi) {
            case 'DadosPessoais':
                $("#DadosPessoais").addClass("active");
                break;
            case 'Documentos':
                $("#DadosPessoais, #Documentos").addClass("active");
                break;
            case 'DocEscolares':
                $("#DadosPessoais, #Documentos, #DocEscolares").addClass("active");
                break;
            case 'Resumo':
                $("#DadosPessoais, #Documentos, #DocEscolares, #Resumo").addClass("active");
                break;
        }

        $(".fs").animate({ opacity: 0 }).css({ 'display': 'none', 'position': 'relative' });
        $("#" + idFs).css({ 'display': 'block', 'position': 'relative' }).animate({ opacity: 1 }, 600);
    }
};
