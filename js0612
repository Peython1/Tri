var obterDataFormatada = function () {
    var dayName = new Array("Domingo", "Segunda", "Terça", "Quarta", "Quinta", "Sexta", "Sábado");
    var monName = new Array("janeiro", "fevereiro", "março", "abril", "maio", "junho", "julho", "agosto", "setembro", "outubro", "novembro", "dezembro");
    var now = new Date;
    return dayName[now.getDay()] + ", " + now.getDate() + " de " + monName[now.getMonth()] + " de " + now.getFullYear();
};

function fnShowHidePass(olho, senha) {
    if ($(senha).attr('type') == 'text') {
        $(senha).attr('type', 'password');
        $(olho).removeClass("fas fa-eye cursor-ponteiro").addClass("fas fa-eye-slash cursor-ponteiro");
    } else {
        $(senha).attr('type', 'text')
        $(olho).removeClass("fas fa-eye-slash cursor-ponteiro").addClass("fas fa-eye cursor-ponteiro");
    }
}


function validarEmail(olho, senha) {
    if ($(senha).attr('type') == 'text') {
        $(senha).attr('type', 'password');
