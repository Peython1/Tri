    $.fn.calendarioEstacio = function (options) {
        var $calendario = this,
            datas;

        function setupPlugin() {
            options = $.extend({
                dataAtual: new Date(2015, 1, 1),
                diasMarcados: [{ Disciplina: 'Matemática', Dia: new Date(2015, 1, 5) }],
                language: 'pt-BR'
            }, options);

            datas = $.fn.datepicker.dates[options.language];
        }

        function setupHtml() {
            var table,
                html;

            table = '<table class=\"table\">' +
                        '<thead>' +
                            '<tr class="cabecalho">' +
                                '<th class="text-center mes-anterior"><i class="ion-arrow-left-c"></i></th>' +
                                '<th class="text-center titulo" colspan="5"></th>' +
                                '<th class="text-center mes-proximo"><i class="ion-arrow-right-c"></i></th>' +
                            '</tr>' +
                        '</thead>' +
                        '<tbody>' +
                        '</tbody>' +
                    '</table>';


            $calendario.append(table);

            var $cabecalho = $calendario.find('thead > tr:last')

            html = '<tr>';
            for (var i = 0; i < 7 ; i++) {
                html += '<td class="dias-semana">' + datas.days[(i % 7)].split('')[0].toUpperCase() + '</th>';
            }
            html += '</tr>';

            $(html).insertAfter($cabecalho);

            $('.mes-anterior').click(function () {
                options.dataAtual.setMonth(options.dataAtual.getMonth() - 1);
                atualizarCalendario();
            });

            $('.mes-proximo').click(function () {
                options.dataAtual.setMonth(options.dataAtual.getMonth() + 1);
                atualizarCalendario();
            })

            atualizarCalendario();
        }

        function quantidadeDiasMes(month, year) {
            return new Date(year, month + 1, 0).getDate();

        }

        function atualizarCalendario() {
            var $dias = $calendario.find('tbody'),
                $titulo = $calendario.find('.titulo'),
                dataAtual = options.dataAtual,
                dataInicio = {},
                inicioDiaSemana = '',
                html = '';

            $dias.empty();

            $titulo.text(datas.months[dataAtual.getMonth()] + " " + dataAtual.getFullYear());

            dataInicio = new Date(dataAtual.getFullYear(), dataAtual.getMonth(), 1);
            inicioDiaSemana = dataInicio.getDay();

            for (var j = 0; j < 42; j++) {
                if (j % 7 == 0) {
                    html = '<tr>';
                }

                if ((j < inicioDiaSemana) || (j >= inicioDiaSemana + quantidadeDiasMes(dataAtual.getMonth(), dataAtual.getFullYear()))) {
                    html += '<td></td>';
                } else {
                    if ($.grep(options.diasMarcados, function (e) { return e.Dia.valueOf() == dataInicio.valueOf(); }).length > 0) {
                        html += '<td>' + dataInicio.getDate() + '</td>';
                    } else {
                        html += '<td>' + dataInicio.getDate() + '</td>';
                    }
                    dataInicio.setDate(dataInicio.getDate() + 1);
                    dataInicio.setHours(0, 0, 0, 0);
                }

                if (j % 7 == 6) {
                    html += '</tr>'
                    if ($(html).find('td:not(:empty)').length > 0) {
                        $dias.append(html);
                    }
                }
            }
        }

        setupPlugin();
        setupHtml();
    }

